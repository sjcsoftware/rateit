{
  "name": "rateit",
  "version": "1.0.4",
  "description": "A beautiful macOS desktop app for rating and cataloguing your music library.",
  "author": "Cha Seungjoon",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --publish never && node scripts/rename-x64-to-x86-64.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^5.0.0"
  },
  "build": {
    "appId": "com.chaseungjun.rateit",
    "productName": "RateIt",
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "RateIt",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*",
      "!backend/.env",
      "!backend/ratings.db",
      "!backend/rateit_session.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
